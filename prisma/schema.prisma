generator client {
  provider = "prisma-client-js"
  previewFeatures = ["clientExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  domain        String
  apiKeyHash    String
  active        Boolean  @default(true)
  branding      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products      Product[]
  customers     Customer[]
  orders        Order[]
  subscriptions Subscription[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]

  @@index([slug])
  @@index([domain])
}

model Product {
  id            String   @id @default(cuid())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String
  stripeProductId String   @unique
  stripePriceId String   @unique
  name          String
  description   String?
  amount        Int      // in cents/currency smallest unit
  currency      String   @default("usd")
  billingType   BillingType
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, active])
  @@index([stripePriceId])
}

model Customer {
  id            String   @id @default(cuid())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String
  stripeCustomerId String   @unique
  email         String
  name          String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, stripeCustomerId])
  @@index([tenantId, email])
}

model Order {
  id                    String   @id @default(cuid())
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  tenantId              String
  customer              Customer @relation(fields: [customerId], references: [id])
  customerId            String
  stripeCheckoutSessionId String   @unique
  stripePaymentIntentId String   @unique
  stripeSubscriptionId  String   @unique
  amount                Int
  currency              String   @default("usd")
  status                OrderStatus
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([stripeCheckoutSessionId])
  @@index([stripePaymentIntentId])
  @@index([stripeSubscriptionId])
}

model Subscription {
  id                  String   @id @default(cuid())
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  tenantId            String
  customer            Customer @relation(fields: [customerId], references: [id])
  customerId          String
  stripeSubscriptionId String   @unique
  status              SubscriptionStatus
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([stripeSubscriptionId])
}

model WebhookEvent {
  id        String   @id @default(cuid())
  stripeEventId String   @unique
  type      String
  processed Boolean  @default(false)
  payload   Json
  createdAt DateTime @default(now())

  @@index([stripeEventId])
  @@index([processed])
}

model ApiKey {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  keyHash   String
  active    Boolean  @default(true)
  lastUsedAt DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, active])
  @@index([keyHash])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  userId    String   // Could be admin user ID or tenant user ID
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

enum BillingType {
  one_time
  subscription
}

enum OrderStatus {
  pending
  processing
  paid
  failed
  cancelled
  refunded
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
}